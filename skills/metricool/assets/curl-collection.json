{
  "info": {
    "name": "Metricool API Collection",
    "description": "Complete Metricool API endpoints for Postman/Insomnia",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://app.metricool.com/api" },
    { "key": "user_token", "value": "YOUR_TOKEN" },
    { "key": "user_id", "value": "YOUR_USER_ID" },
    { "key": "blog_id", "value": "YOUR_BLOG_ID" }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-Mc-Auth" },
      { "key": "value", "value": "{{user_token}}" },
      { "key": "in", "value": "header" }
    ]
  },
  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Brands",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/simpleProfiles?blogId={{blog_id}}&userId={{user_id}}"
          }
        },
        {
          "name": "Get Authenticated Brands",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/profiles-auth?blogId={{blog_id}}&userId={{user_id}}"
          }
        },
        {
          "name": "Get Max Profiles",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/max-profiles?blogId={{blog_id}}&userId={{user_id}}"
          }
        },
        {
          "name": "Add Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/add-profile?blogId={{blog_id}}&userId={{user_id}}"
          }
        },
        {
          "name": "Delete Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/delete-profile?blogId={{blog_id}}&userId={{user_id}}"
          }
        }
      ]
    },
    {
      "name": "Instagram Analytics",
      "item": [
        {
          "name": "Get Posts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/stats/instagram/posts?blogId={{blog_id}}&userId={{user_id}}&start=1704067200&end=1706745600",
              "query": [
                { "key": "blogId", "value": "{{blog_id}}" },
                { "key": "userId", "value": "{{user_id}}" },
                { "key": "start", "value": "1704067200" },
                { "key": "end", "value": "1706745600" }
              ]
            }
          }
        },
        {
          "name": "Get Reels",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/stats/instagram/reels?blogId={{blog_id}}&userId={{user_id}}&start=1704067200&end=1706745600"
          }
        },
        {
          "name": "Get Stories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/stats/instagram/stories?blogId={{blog_id}}&userId={{user_id}}&start=1704067200&end=1706745600"
          }
        }
      ]
    },
