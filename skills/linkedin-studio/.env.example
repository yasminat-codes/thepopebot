# ============================================================
# LinkedIn Studio — Environment Variables
# Copy this to your Claude Code settings or export in shell
# ============================================================
#
# REQUIRED vars must be set for the pipeline to run.
# OPTIONAL vars enable specific integrations — the pipeline
# degrades gracefully when they are missing.
# AUTO vars have sensible defaults and rarely need changing.
#
# Tip: To set these in Claude Code, add them under the "env"
# key in ~/.claude/settings.json (see docs/README.md).
# ============================================================

# --- Neon PostgreSQL (REQUIRED) ---
# Connection string for your Neon database.
# Get this from: https://console.neon.tech → Your Project → Connection Details
# Must include ?sslmode=require for Neon connections.
NEON_DATABASE_URL=postgresql://user:password@ep-example-123.us-east-2.aws.neon.tech/linkedin_studio?sslmode=require

# Connection pool size. Default 5 is fine for single-user usage.
# Increase to 10 if running multiple pipelines concurrently.
NEON_POOL_SIZE=5

# --- Metricool (REQUIRED for scheduling) ---
# API key for Metricool — used for batch scheduling and analytics.
# Get API key from: https://app.metricool.com → Settings → API
METRICOOL_API_KEY=your_metricool_api_key

# Numeric user ID from Metricool account settings (not the username).
METRICOOL_USER_ID=your_metricool_user_id

# Metricool API base URL. You should not need to change this.
METRICOOL_BASE_URL=https://app.metricool.com/api/v2

# --- Reddit (REQUIRED for research) ---
# Reddit API credentials for PRAW (pain point mining + trend validation).
# Create an app at: https://www.reddit.com/prefs/apps → Create App → Script type
# IMPORTANT: App type must be "script", not "web app".
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Your Reddit account username and password (required for script-type apps).
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# User agent string sent with Reddit API requests.
REDDIT_USER_AGENT=linkedin-studio/1.0

# --- Pushshift (AUTO — used alongside Reddit) ---
# Pushshift API for historical Reddit post retrieval.
PUSHSHIFT_BASE_URL=https://api.pushshift.io/reddit

# --- SerpAPI (REQUIRED for LinkedIn scraping fallback) ---
# Fallback search engine when Playwright LinkedIn scraping is blocked.
# Get API key from: https://serpapi.com/manage-api-key
# Used sparingly — only when Playwright encounters CAPTCHAs or login walls.
SERPAPI_KEY=your_serpapi_key
SERPAPI_BASE_URL=https://serpapi.com/search

# --- Canva MCP (OPTIONAL for design creation) ---
# Enables ls:canva-designer skill for branded carousel and image creation.
# Get API key from: https://www.canva.com/developers/
# Requires Canva MCP server to be running.
CANVA_API_KEY=your_canva_api_key

# --- OpenAI (OPTIONAL for image generation) ---
# Used by ls:visual-prompter for DALL-E 3 image generation and by
# ls:research-engine for topic similarity embeddings (duplicate detection).
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key

# Image generation model. Currently supports dall-e-3.
OPENAI_IMAGE_MODEL=dall-e-3

# --- Google Imagen (OPTIONAL — alternative image generation) ---
# Alternative to DALL-E 3 via Google Vertex AI Imagen.
# Requires Vertex AI enabled on your GCP project with a service account
# that has the Vertex AI User role.
GOOGLE_IMAGEN_PROJECT_ID=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Playwright (AUTO — headless browser for LinkedIn scraping) ---
# Controls the headless Chromium instance used by ls:creator-analyzer.
# Set PLAYWRIGHT_HEADLESS=false for debugging scraping issues.
PLAYWRIGHT_HEADLESS=true

# Timeout in milliseconds for Playwright page loads and navigation.
PLAYWRIGHT_TIMEOUT_MS=30000
